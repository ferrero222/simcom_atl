## 📦 Modules

### 🔌 General Modem Functions (`atl_mdl_general`)

```c
// Modem reset
atl_mdl_modem_reset(callback);

// Get real-time modem data
static void rtd_callback(bool success, atl_mdl_rtd_t* data) {
    if (success) {
        printf("IMEI: %s\n", data->modem_imei);
        printf("Operator: %s\n", data->sim_operator);
        printf("RSSI: %d\n", data->sim_rssi);
    }
}
atl_mdl_rtd(rtd_callback);
```

### 🌐 TCP/IP Connectivity (`atl_mdl_tcp`)

```c
// GPRS initialization
atl_mdl_gprs_init(gprs_cb);

// Socket configuration
atl_mdl_gprs_socket_config(socket_cb);

// Server connection
atl_mdl_gprs_socket_connect("TCP", "api.example.com", "80", connect_cb);

// Data transmission
atl_mdl_gprs_socket_send_recieve("Hello World!", send_cb);

// Cleanup
atl_mdl_gprs_deinit(deinit_cb);
```

### 📱 SMS Handling (`atl_mdl_sms`)

```c
// Send SMS
atl_mdl_sms_send_text("+1234567890", "Message text", sms_cb);

// Read SMS
static void sms_read_cb(bool success, atl_mdl_sms_msg_t* msg) {
    if (success) {
        printf("SMS from %s: %s\n", msg->num, msg->msg);
    }
}
atl_mdl_sms_read(1, sms_read_cb);

// Delete SMS
atl_mdl_sms_delete(1, delete_cb);

// SMS notification setup
atl_urc_t sms_urc = {
    .prefix = "+CMTI",
    .cb = atl_mdl_sms_urc_cb
};
atl_urc_enqueue(&sms_urc);
```

## 💡 Examples

### Complete Modem Initialization with TCP

```c
void complete_modem_setup(void) {
    // 1. Basic modem initialization
    atl_mdl_modem_init([](bool success) {
        if (!success) return;
        
        // 2. GPRS setup
        atl_mdl_gprs_init([](bool success) {
            if (!success) return;
            
            // 3. TCP socket configuration
            atl_mdl_gprs_socket_config([](bool success) {
                if (!success) return;
                
                // 4. Connect to server
                atl_mdl_gprs_socket_connect("TCP", "httpbin.org", "80", 
                    [](bool success) {
                        if (success) {
                            // 5. Send HTTP request
                            char http_req[] = 
                                "GET /get HTTP/1.1\r\n"
                                "Host: httpbin.org\r\n"
                                "\r\n";
                            atl_mdl_gprs_socket_send_recieve(http_req, NULL);
                        }
                    });
            });
        });
    });
}
```

### SMS Auto-Reply System

```c
static void incoming_sms_handler(ringslice_t urc_slice) {
    uint16_t index = 0;
    ringslice_scanf(urc_slice, "+CMTI:%*[^,],%d\r", &index);
    
    if (index != 0) {
        atl_mdl_sms_read(index, [](bool success, atl_mdl_sms_msg_t* msg) {
            if (success) {
                // Auto-reply
                char reply[100];
                snprintf(reply, sizeof(reply), 
                         "Hi! Received your message: %.50s", msg->msg);
                atl_mdl_sms_send_text(msg->num, reply, NULL);
                
                // Delete original message
                atl_mdl_sms_delete(1, NULL);
            }
        });
    }
}

void setup_sms_auto_reply(void) {
    atl_urc_t sms_urc = {
        .prefix = "+CMTI",
        .cb = incoming_sms_handler
    };
    atl_urc_enqueue(&sms_urc);
    
    // Set SMS format to text mode
    atl_mdl_sms_format_set(1, NULL);
}
```

## ⚙️ Configuration

### Library Configuration (`atl_core.h`)

```c
#define ATL_ENTITY_QUEUE_SIZE    10    // Command queue size
#define ATL_URC_QUEUE_SIZE       10    // URC queue size
#define ATL_MEMORY_POOL_SIZE     2048  // Memory pool size
#define ATL_DEBUG_ENABLED        1     // Debug output
#define ATL_FREQUENCY            10    // Processing frequency (Hz)
```

### Customization

```c
// Override critical sections for your RTOS
__attribute__((weak)) void atl_crit_enter(void) {
    // Your critical section entry
    // Example: taskENTER_CRITICAL();
}

__attribute__((weak)) void atl_crit_exit(void) {
    // Your critical section exit
    // Example: taskEXIT_CRITICAL();
}
```

### Memory Configuration

The library uses TLSF (Two-Level Segregate Fit) memory allocator. Adjust pool size based on your needs:

```c
#define ATL_MEMORY_POOL_SIZE     // Default: 2048 bytes
// Recommended:
// - Simple applications: 1024 bytes
// - TCP + SMS: 2048 bytes  
// - Complex applications: 4096+ bytes
```

## 🔧 Porting Guide

### 1. Implement Required Functions

```c
// Printf function (for debugging)
void your_printf(const char* format, ...) {
    va_list args;
    va_start(args, format);
    // Your output implementation (UART, SWO, etc.)
    va_end(args);
}

// UART write function
uint16_t your_uart_write(uint8_t* data, uint16_t len) {
    // Your UART transmission code
    return transmitted_bytes;
}
```

### 2. Provide Ring Buffer

```c
// Your ring buffer implementation
extern uint8_t  uart_rx_buffer[1024];
extern uint16_t uart_rx_head;
extern uint16_t uart_rx_tail;
```

### 3. Critical Sections (for RTOS)

```c
// FreeRTOS example
void atl_crit_enter(void) {
    taskENTER_CRITICAL();
}

void atl_crit_exit(void) {
    taskEXIT_CRITICAL();
}
```

